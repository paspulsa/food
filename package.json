{
  "name": "kpkembar",
  "version": "1.0.0",
  "description": "Serverless Backend untuk ShopeeFood Clone dengan Hono dan Cloudflare V8 Pages",
  "main": "functions/api/[[path]].ts",
  "scripts": {
    "dev": "wrangler pages dev public",
    "db:create": "wrangler d1 create kpkembar",
    "db:migrate": "wrangler d1 execute kpkembar --local --file=./schema.sql",
    "db:migrate:prod": "wrangler d1 execute kpkembar --remote --file=./schema.sql"
  },
  "dependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240320.1",
    "typescript": "^5.0.0",
    "wrangler": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
